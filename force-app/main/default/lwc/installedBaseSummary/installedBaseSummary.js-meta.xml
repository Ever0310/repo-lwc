<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Base installée</masterLabel>
    <description>Résumé de la base installée (panneaux solaires, onduleur, rendement) pour une Messaging Session.</description>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>MessagingSession</object>
            </objects>
            <property name="panelCount" type="Integer" default="2" label="Nombre de panneaux" description="Nombre de panneaux solaires affichés."/>
            <property name="inverterCount" type="Integer" default="1" label="Nombre d'onduleurs" description="Nombre d'onduleurs affichés."/>
            <property name="rendementPercent" type="Integer" default="63" label="Rendement (%)" description="Rendement en pourcentage (affiché en orange si non optimal)."/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
